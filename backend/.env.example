# SEC EDGAR requires a descriptive User-Agent (company/app + contact email)
SEC_EDGAR_USER_AGENT=QuantPilot/1.0 (your-email@example.com)

# Required for full agent analysis and ChromaDB embeddings
OPENAI_API_KEY=sk-your-key-here

# Comma-separated CORS origins (add your Vercel URL after deploy)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional: override monorepo root if MCP server path differs on your host
# QUANTPILOT_ROOT=/path/to/quantpilot
